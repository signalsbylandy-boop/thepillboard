{
  "name": "@pillboard/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply pillboard-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply pillboard-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "*",
    "wrangler": "^3.101.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "*"
  }
}
