# ─── Cloudflare ─────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_secret_in_production
COOKIE_SECRET=change_this_to_a_random_32_char_secret

# ─── OAuth Providers (optional) ──────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (optional) ────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=noreply@thepillboard.com

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=https://thepillboard.com
API_URL=https://api.thepillboard.com
NODE_ENV=development

# ─── Rate Limiting ───────────────────────────────────────────────────────────
SUBMISSION_COOLDOWN_SECONDS=30
COMMENT_COOLDOWN_SECONDS=10
MAX_SUBMISSIONS_PER_HOUR=5
