{
  "name": "@pillboard/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --local",
    "build": "tsc",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply pillboard-db --local"
  },
  "dependencies": {
    "@pillboard/db": "*",
    "@pillboard/types": "*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.17",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "*",
    "wrangler": "^3.101.0"
  }
}
